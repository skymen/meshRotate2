{
  "languageTag": "en-US",
  "fileDescription": "Strings for mesh3d_rotate_enhanced.",
  "text": {
    "behaviors": {
      "mesh3d_rotate_enhanced": {
        "name": "Mesh 3D Rotate Enhanced",
        "description": "Enhanced 3D mesh rotation system with direct WorldInfo override",
        "help-url": "https://www.construct.net",
        "aceCategories": {
          "Mesh3DRotate": "Mesh3DRotate"
        },
        "properties": {
          "rotation_x": {
            "name": "Rotation X",
            "desc": "X-axis rotation in degrees"
          },
          "rotation_y": {
            "name": "Rotation Y",
            "desc": "Y-axis rotation in degrees"
          },
          "rotation_z": {
            "name": "Rotation Z",
            "desc": "Z-axis rotation in degrees"
          },
          "scale_x": {
            "name": "Scale X",
            "desc": "X-axis scale multiplier"
          },
          "scale_y": {
            "name": "Scale Y",
            "desc": "Y-axis scale multiplier"
          },
          "offset": {
            "name": "Offset",
            "desc": "Offset in the direction of rotation normal"
          },
          "rotation_z_extra": {
            "name": "Rotation Z Extra",
            "desc": "Additional Z-axis rotation applied first (before main rotations)"
          },
          "auto_update_mesh": {
            "name": "Auto Update Mesh",
            "desc": "Automatically recalculate the mesh when the object's size, angle, or origin changes"
          }
        },
        "actions": {
          "ForceUpdateMesh": {
            "list-name": "Force Update Mesh",
            "display-text": "{my}: Force update mesh",
            "description": "Manually recalculate the mesh rotation. Useful when Auto Update Mesh is disabled.",
            "params": {}
          },
          "SetAutoUpdateMesh": {
            "list-name": "Set Auto Update Mesh",
            "display-text": "{my}: Set auto update mesh to {0}",
            "description": "Enable or disable automatic mesh recalculation when the object's geometry changes",
            "params": {
              "enabled": {
                "name": "Enabled",
                "desc": "Whether to automatically update the mesh on geometry changes",
                "items": {
                  "enabled": "Enabled",
                  "disabled": "Disabled"
                }
              }
            }
          },
          "SetInstanceOrigin": {
            "list-name": "Set Origin & Update Mesh",
            "display-text": "{my}: Set origin to ({0}, {1}) and update mesh",
            "description": "Set the object's origin point (0-1 range), then recalculate the mesh. Useful when Auto Update Mesh is disabled.",
            "params": {
              "originX": {
                "name": "Origin X",
                "desc": "Origin X (0 = left, 1 = right)"
              },
              "originY": {
                "name": "Origin Y",
                "desc": "Origin Y (0 = top, 1 = bottom)"
              }
            }
          },
          "SetInstanceSize": {
            "list-name": "Set Size & Update Mesh",
            "display-text": "{my}: Set size to {0}x{1} and update mesh",
            "description": "Set the object's width and height, then recalculate the mesh. Useful when Auto Update Mesh is disabled.",
            "params": {
              "width": {
                "name": "Width",
                "desc": "Object width in pixels"
              },
              "height": {
                "name": "Height",
                "desc": "Object height in pixels"
              }
            }
          },
          "SetMeshSize": {
            "list-name": "Set Mesh Size",
            "display-text": "{my}: Set mesh size to {0}x{1}",
            "description": "Set the number of mesh points for the object",
            "params": {
              "width": {
                "name": "Width",
                "desc": "Number of mesh points horizontally"
              },
              "height": {
                "name": "Height",
                "desc": "Number of mesh points vertically"
              }
            }
          },
          "SetOffset": {
            "list-name": "Set Offset",
            "display-text": "{my}: Set offset to {0}",
            "description": "Set the offset in the direction of rotation normal",
            "params": {
              "offset": {
                "name": "Offset",
                "desc": "Offset value in the direction of rotation normal"
              }
            }
          },
          "SetOriginalZElevation": {
            "list-name": "Set Original Z Elevation",
            "display-text": "{my}: Set original Z elevation to {0}",
            "description": "(Deprecated) No longer needed - use the built-in Z elevation instead. Previously required to work around negative mesh Z limitations.",
            "params": {
              "zElevation": {
                "name": "Z Elevation",
                "desc": "Original Z elevation value"
              }
            }
          },
          "SetRotation": {
            "list-name": "Set Rotation",
            "display-text": "{my}: Set rotation to X: {0}, Y: {1}, Z: {2}",
            "description": "Set the 3D rotation of the object using Euler angles",
            "params": {
              "rotationX": {
                "name": "Rotation X",
                "desc": "X-axis rotation in degrees"
              },
              "rotationY": {
                "name": "Rotation Y",
                "desc": "Y-axis rotation in degrees"
              },
              "rotationZ": {
                "name": "Rotation Z",
                "desc": "Z-axis rotation in degrees"
              }
            }
          },
          "SetRotationFromVectors": {
            "list-name": "Set Rotation From Vectors",
            "display-text": "{my}: Set rotation from up vector ({0},{1},{2}) and forward vector ({3},{4},{5})",
            "description": "Set the 3D rotation of the object from up and forward vectors",
            "params": {
              "upX": {
                "name": "Up X",
                "desc": "Up vector X component"
              },
              "upY": {
                "name": "Up Y",
                "desc": "Up vector Y component"
              },
              "upZ": {
                "name": "Up Z",
                "desc": "Up vector Z component"
              },
              "forwardX": {
                "name": "Forward X",
                "desc": "Forward vector X component"
              },
              "forwardY": {
                "name": "Forward Y",
                "desc": "Forward vector Y component"
              },
              "forwardZ": {
                "name": "Forward Z",
                "desc": "Forward vector Z component"
              }
            }
          },
          "SetRotationZExtra": {
            "list-name": "Set Rotation Z Extra",
            "display-text": "{my}: Set extra Z rotation to {0}",
            "description": "Set the additional Z-axis rotation applied first",
            "params": {
              "rotationZExtra": {
                "name": "Rotation Z Extra",
                "desc": "Additional Z-axis rotation in degrees"
              }
            }
          },
          "SetScale": {
            "list-name": "Set Scale",
            "display-text": "{my}: Set scale to X: {0}, Y: {1}",
            "description": "Set the 3D scale of the object",
            "params": {
              "scaleX": {
                "name": "Scale X",
                "desc": "X-axis scale multiplier"
              },
              "scaleY": {
                "name": "Scale Y",
                "desc": "Y-axis scale multiplier"
              }
            }
          }
        },
        "conditions": {
          "IsAutoUpdateMesh": {
            "list-name": "Is Auto Update Mesh enabled",
            "display-text": "{my}: Auto update mesh is enabled",
            "description": "True if auto update mesh is currently enabled",
            "params": {}
          }
        },
        "expressions": {
          "MeshZOffset": {
            "translated-name": "MeshZOffset",
            "description": "(Deprecated) No longer needed - negative mesh Z values are now supported. Always returns 0.",
            "params": {}
          },
          "Offset": {
            "translated-name": "Offset",
            "description": "Get the current offset value",
            "params": {}
          },
          "OriginalZElevation": {
            "translated-name": "OriginalZElevation",
            "description": "(Deprecated) No longer needed - use the built-in Z expression instead. Returns the instance's Z elevation.",
            "params": {}
          },
          "RotationX": {
            "translated-name": "RotationX",
            "description": "Get the current X rotation in degrees",
            "params": {}
          },
          "RotationY": {
            "translated-name": "RotationY",
            "description": "Get the current Y rotation in degrees",
            "params": {}
          },
          "RotationZ": {
            "translated-name": "RotationZ",
            "description": "Get the current Z rotation in degrees",
            "params": {}
          },
          "RotationZExtra": {
            "translated-name": "RotationZExtra",
            "description": "Get the current extra Z rotation value",
            "params": {}
          },
          "ScaleX": {
            "translated-name": "ScaleX",
            "description": "Get the current X scale multiplier",
            "params": {}
          },
          "ScaleY": {
            "translated-name": "ScaleY",
            "description": "Get the current Y scale multiplier",
            "params": {}
          }
        }
      }
    }
  }
}